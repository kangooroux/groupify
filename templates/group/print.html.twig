<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Round {{ round }} — Tables</title>
    <link rel="stylesheet" href="{{ asset('css/print.css') }}">
</head>
<body>
<main>
    <button class="print-btn" id="print-btn">Print</button>
    <h1>Round {{ round }} — Tables</h1>
    <div class="layout">
        <div class="groups">
            {% for group in groups %}
            <div class="group">
                <h2 class="group__title">Table {{ loop.index }}</h2>
                <ul class="group__list">
                    {% for player in group %}
                    <li class="group__player">{{ player }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}
        </div>
        <div class="roster">
            <h2 class="roster__heading">Players</h2>
            {% set names = playerTable|keys %}
            {% set half = (names|length / 2)|round(0, 'ceil') %}
            <div class="roster__columns">
                <ul class="roster__list">
                    {% for name in names|slice(0, half) %}
                    <li class="roster__item">
                        <span class="roster__name">{{ name }}</span>
                        <span class="roster__table">T{{ playerTable[name] }}</span>
                    </li>
                    {% endfor %}
                </ul>
                <ul class="roster__list">
                    {% for name in names|slice(half) %}
                    <li class="roster__item">
                        <span class="roster__name">{{ name }}</span>
                        <span class="roster__table">T{{ playerTable[name] }}</span>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</main>
<script src="{{ asset('js/print.js') }}" type="module"></script>
</body>
</html>
