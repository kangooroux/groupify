<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Round {{ round }} — Tables</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        @page {
            size: A4 portrait;
            margin: 1.5cm;
        }

        body {
            font-family: system-ui, sans-serif;
            font-size: 11pt;
            color: #000;
            margin: 0;
            padding: 1.5cm;
            background: #fff;
        }

        h1 { font-size: 16pt; margin: 0 0 0.75cm; }

        .layout { display: flex; gap: 1cm; align-items: flex-start; }

        .groups { flex: 1; display: flex; flex-wrap: wrap; gap: 0.5cm; align-content: flex-start; }

        .group {
            flex: 0 1 calc(50% - 0.25cm);
            border: 1px solid #999;
            border-radius: 4pt;
            padding: 0.4cm;
            break-inside: avoid;
        }

        .group__title { font-size: 10pt; font-weight: 700; margin: 0 0 0.2cm; color: #000; }

        .group__list { margin: 0; padding-left: 1em; }
        .group__player { padding: 1pt 0; font-size: 10pt; }

        .roster {
            flex: 0 0 42%;
            border: 1px solid #999;
            border-radius: 4pt;
            padding: 0.4cm;
            break-inside: avoid;
        }

        .roster h2 { font-size: 10pt; font-weight: 700; margin: 0 0 0.2cm; }

        .roster__columns { display: flex; gap: 0.4cm; }
        .roster__list { flex: 1; margin: 0; padding: 0; list-style: none; }

        .roster__item {
            display: flex;
            justify-content: space-between;
            gap: 0.3cm;
            padding: 1pt 0;
            border-bottom: 0.5pt solid #ccc;
            font-size: 9pt;
        }
        .roster__item:last-child { border-bottom: none; }
        .roster__name { min-width: 0; }
        .roster__table { white-space: nowrap; flex-shrink: 0; font-weight: 700; }

        .print-btn {
            display: block;
            margin-bottom: 0.75cm;
            padding: 0.3cm 0.8cm;
            background: #2563eb;
            color: #fff;
            border: none;
            border-radius: 4pt;
            font-size: 10pt;
            cursor: pointer;
        }

        @media print {
            .print-btn { display: none; }
            body { padding: 0; }
        }
    </style>
</head>
<body>
    <button class="print-btn" onclick="window.print()">Print</button>
    <h1>Round {{ round }} — Tables</h1>
    <div class="layout">
        <div class="groups">
            {% for group in groups %}
            <div class="group">
                <p class="group__title">Table {{ loop.index }}</p>
                <ul class="group__list">
                    {% for player in group %}
                    <li class="group__player">{{ player }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}
        </div>
        <div class="roster">
            <h2>Players</h2>
            {% set names = playerTable|keys %}
            {% set half = (names|length / 2)|round(0, 'ceil') %}
            <div class="roster__columns">
                <ul class="roster__list">
                    {% for name in names|slice(0, half) %}
                    <li class="roster__item">
                        <span class="roster__name">{{ name }}</span>
                        <span class="roster__table">T{{ playerTable[name] }}</span>
                    </li>
                    {% endfor %}
                </ul>
                <ul class="roster__list">
                    {% for name in names|slice(half) %}
                    <li class="roster__item">
                        <span class="roster__name">{{ name }}</span>
                        <span class="roster__table">T{{ playerTable[name] }}</span>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</body>
</html>
