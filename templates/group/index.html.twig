{% extends 'base.html.twig' %}
{% block title %}Commander Pods Randomizer{% endblock %}
{% block body %}
<main class="container">
    <h1>Commander Pods Randomizer</h1>
    {% if errors is not empty %}
    <ul class="form-errors" aria-live="polite" aria-atomic="true">
        {% for error in errors %}<li>{{ error }}</li>{% endfor %}
    </ul>
    {% endif %}

    <form method="post" action="{{ path('app_group') }}" class="form">
        <input type="hidden" name="_token" value="{{ csrf_token('randomize') }}">

        <fieldset class="pods-fieldset">
            <legend class="pods-fieldset__legend">Custom pods <span class="pods-fieldset__hint">(optional — pre-assign players before randomizing)</span></legend>
            <div id="pods-list" data-max-players="{{ maxPlayersPerPod }}">
                {% for pod in customPods %}
                <div class="pod-entry">
                    <span class="pod-entry__title">Custom pod {{ loop.index }}</span>
                    <textarea name="pod_players[]" class="pod-entry__players" rows="4" placeholder="Pre-assigned players (one per line, max 4)" aria-label="Players for custom pod {{ loop.index }}">{{ pod.players | join('\n') }}</textarea>
                    <span class="pod-entry__warning" role="alert" hidden>Maximum {{ maxPlayersPerPod }} players per pod.</span>
                    <button type="button" class="pod-entry__remove">Remove</button>
                </div>
                {% endfor %}
            </div>
            <button type="button" id="add-pod" class="btn-add-pod">+ Add a pod</button>
        </fieldset>

        <label for="players" class="form__label">Remaining players to randomize (one per line)</label>
        <textarea id="players" name="players" class="form__textarea" rows="10"
            placeholder="Alice&#10;Bob&#10;Charlie">{{ rawInput }}</textarea>

        <div class="form__actions">
            <button type="submit" class="form__submit">
                {% if roundNumber > 0 %}Round {{ roundNumber + 1 }}{% else %}Randomize{% endif %}
            </button>
            {% if roundNumber > 0 %}
            <form method="post" action="{{ path('app_clear_history') }}" id="clear-history-form">
                <input type="hidden" name="_token" value="{{ csrf_token('clear_history') }}">
                <button type="submit" class="btn-clear-history">
                    Reset rounds ({{ roundNumber }} round{{ roundNumber > 1 ? 's' : '' }})
                </button>
            </form>
            {% endif %}
        </div>
    </form>

    {% if groups is not empty %}
    <div class="results-layout">
        <section class="results">
            <h2>Round {{ roundNumber }} — Tables</h2>
            <div class="groups">
                {% for group in groups %}
                <div class="group">
                    <h3 class="group__title">{{ group.name }}</h3>
                    <ul class="group__list">
                        {% for player in group.players %}<li class="group__player">{{ player }}</li>{% endfor %}
                    </ul>
                </div>
                {% endfor %}
            </div>
        </section>
        <section class="player-list">
            <h2>Players</h2>
            <div class="player-grid">
                {% for entry in playerList %}
                <div class="player-row">
                    <span class="player-row__name">{{ entry.name }}</span>
                    <span class="player-row__table">{{ entry.table }}</span>
                </div>
                {% endfor %}
            </div>
        </section>
    </div>
    {% endif %}
</main>

<template id="pod-template">
    <div class="pod-entry">
        <span class="pod-entry__title"></span>
        <textarea name="pod_players[]" class="pod-entry__players" rows="4" placeholder="Pre-assigned players (one per line, max 4)" aria-label="Players for custom pod"></textarea>
        <span class="pod-entry__warning" role="alert" hidden>Maximum {{ maxPlayersPerPod }} players per pod.</span>
        <button type="button" class="pod-entry__remove">Remove</button>
    </div>
</template>

<script src="{{ asset('js/app.js') }}" defer></script>
{% endblock %}
