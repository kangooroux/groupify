{
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "symfony/asset": "^7.4",
        "symfony/dotenv": "^7.4",
        "symfony/framework-bundle": "^7.4",
        "symfony/rate-limiter": "^7.4",
        "symfony/runtime": "^7.4",
        "symfony/security-csrf": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/yaml": "^7.4",
        "twig/extra-bundle": "^3.24"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {}
}
